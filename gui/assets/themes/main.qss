/* ============================================================
   Bootstrap 5-inspired light theme for 3psLCCA
   Tokens are defined in gui/theme.py and substituted at runtime.

   $primary         brand green
   $primary-hover   ~13% darker (button hover)
   $primary-active  ~25% darker (button pressed)
   $white           #ffffff
   $body-bg         app / sidebar background
   $body-color      primary text
   $secondary       muted / secondary text
   $border          standard border
   $border-subtle   slightly darker border
   $muted           disabled / placeholder
   $surface         neutral hover background
   $surface-active  neutral pressed background
   ============================================================ */

/* ── Base ───────────────────────────────────────────────────────────────── */
* {
    font-family: "Ubuntu", Arial, sans-serif;
    font-size: 13px;
    color: $body-color;
    outline: none;
}

QWidget {
    background-color: $body-bg;
}

/* ── Form controls — inputs ─────────────────────────────────────────────── */
QLineEdit,
QTextEdit,
QPlainTextEdit {
    background-color: $white;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 6px 12px;
    min-height: 32px;
    color: $body-color;
    selection-background-color: $primary;
    selection-color: #000000;
}

QLineEdit:hover,
QTextEdit:hover {
    border-color: $border-subtle;
}

QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus {
    border: 2px solid $primary;
    padding: 5px 11px;
}

QLineEdit:read-only,
QTextEdit:read-only,
QPlainTextEdit:read-only {
    color: $secondary;
}

QLineEdit:disabled,
QTextEdit:disabled,
QPlainTextEdit:disabled {
    background-color: $body-bg;
    color: $muted;
    border-color: $border;
}

/* ── Form controls — spin boxes ─────────────────────────────────────────── */
QSpinBox,
QDoubleSpinBox {
    background-color: $white;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 6px 12px;
    min-height: 32px;
    color: $body-color;
}

QSpinBox:hover,
QDoubleSpinBox:hover {
    border-color: $border-subtle;
}

QSpinBox:focus,
QDoubleSpinBox:focus {
    border: 2px solid $primary;
    padding: 5px 11px;
}

QSpinBox:disabled,
QDoubleSpinBox:disabled {
    background-color: $body-bg;
    color: $muted;
    border-color: $border;
}

QSpinBox::up-button,
QSpinBox::down-button,
QDoubleSpinBox::up-button,
QDoubleSpinBox::down-button {
    width: 18px;
    border: none;
    background: transparent;
}

/* ── Table-cell spin boxes (transparent, borderless — cell border highlights on focus) ── */
TableSpinBox,
TableDoubleSpinBox {
    background-color: transparent;
    border: none;
    border-radius: 0;
    padding: 0 4px;
    margin: 0;
    min-height: 0;
    color: $body-color;
}

TableSpinBox:hover,
TableDoubleSpinBox:hover {
    background-color: transparent;
    border: none;
    margin: 0;
}

TableSpinBox:focus,
TableDoubleSpinBox:focus {
    background-color: transparent;
    border: none;
    padding: 0 4px;
    margin: 0;
}

TableSpinBox:disabled,
TableDoubleSpinBox:disabled {
    background-color: transparent;
    color: $muted;
    border: none;
}

TableSpinBox::up-button,
TableSpinBox::down-button,
TableDoubleSpinBox::up-button,
TableDoubleSpinBox::down-button {
    width: 0;
    border: none;
    background: transparent;
}


/* ── Table-cell line edit (transparent, borderless — cell border on focus) ── */
TableLineEdit {
    background-color: transparent;
    border: none;
    border-radius: 0;
    padding: 0 4px;
    margin: 0;
    min-height: 0;
    color: $body-color;
    selection-background-color: $primary;
    selection-color: #000000;
}

TableLineEdit:hover {
    background-color: transparent;
    border: none;
    margin: 0;
}

TableLineEdit:focus {
    background-color: transparent;
    border: none;
    padding: 0 4px;
    margin: 0;
}

TableLineEdit:disabled {
    background-color: transparent;
    color: $muted;
    border: none;
}

/* ── Form controls — combo box ──────────────────────────────────────────── */
QComboBox {
    background-color: $white;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 6px 36px 6px 12px;
    min-height: 32px;
    color: $body-color;
    combobox-popup: 0;
}

QComboBox:hover {
    border-color: $border-subtle;
}

QComboBox:focus {
    border: 2px solid $primary;
    padding: 5px 35px 5px 11px;
}

QComboBox:disabled {
    background-color: $body-bg;
    color: $muted;
    border-color: $border;
}

QComboBox[validationState="#dc3545"] {
    border: 1px solid #dc3545;
}

QComboBox[validationState="orange"] {
    border: 1px solid orange;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 32px;

}


/* ── Dropdown popup list ────────────────────────────────────────────────── */
QComboBox QAbstractItemView {
    background-color: $white;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 6px 0;
    outline: none;
    selection-background-color: transparent;
    show-decoration-selected: 1;
}

QComboBox QAbstractItemView::item {
    padding: 10px 16px;
    color: $body-color;
    border: none;
    border-radius: 4px;
    margin: 1px 6px;
    min-height: 20px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: $surface;
    color: $body-color;
}

QComboBox QAbstractItemView::item:selected {
    background-color: $surface-active;
    color: $body-color;
}



/* ── Form controls — check box ──────────────────────────────────────────── */
QCheckBox {
    spacing: 8px;
    color: $body-color;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid $border;
    border-radius: 4px;
    background-color: $white;
}

QCheckBox::indicator:hover {
    border-color: $border-subtle;
}

QCheckBox::indicator:checked {
    background-color: $primary;
    border-color: $primary;
}

QCheckBox::indicator:checked:hover {
    background-color: $primary-hover;
    border-color: $primary-hover;
}

QCheckBox::indicator:disabled {
    background-color: $body-bg;
    border-color: $border;
}

QCheckBox:disabled {
    color: $muted;
}

/* ── Form controls — radio button ───────────────────────────────────────── */
QRadioButton {
    spacing: 8px;
    color: $body-color;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid $border;
    border-radius: 8px;
    background-color: $white;
}

QRadioButton::indicator:hover {
    border-color: $border-subtle;
}

QRadioButton::indicator:checked {
    background-color: $primary;
    border-color: $primary;
}

QRadioButton::indicator:checked:hover {
    background-color: $primary-hover;
    border-color: $primary-hover;
}

QRadioButton::indicator:disabled {
    background-color: $body-bg;
    border-color: $border;
}

QRadioButton:disabled {
    color: $muted;
}

/* ── Buttons ────────────────────────────────────────────────────────────── */
QPushButton {
    background-color: $white;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 6px 16px;
    min-height: 32px;
    color: $body-color;
    font-weight: 500;
}

QPushButton:hover {
    background-color: $surface;
    border-color: $border-subtle;
    color: $body-color;
}

QPushButton:pressed {
    background-color: $surface-active;
    border-color: $muted;
}

/* Primary action button (QPushButton::default) */
QPushButton:default {
    background-color: $primary;
    color: #000000;
    border: 1px solid $primary;
    font-weight: 600;
}

QPushButton:default:hover {
    background-color: $primary-hover;
    border-color: $primary-hover;
    color: #000000;
}

QPushButton:default:pressed {
    background-color: $primary-active;
    border-color: $primary-active;
    color: #000000;
}

QPushButton:disabled {
    background-color: $body-bg;
    color: $muted;
    border-color: $border;
}

/* ── Tab bar ────────────────────────────────────────────────────────────── */
QTabWidget::pane {
    background-color: $white;
    border: none;
    border-top: 1px solid $border;
}

QTabBar {
    background: transparent;
}

QTabBar::tab {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 18px;
    margin-right: 4px;
    color: $secondary;
    font-weight: 500;
}

QTabBar::tab:selected {
    border-bottom: 2px solid $primary;
    color: $body-color;
    font-weight: 600;
}

QTabBar::tab:hover:!selected {
    color: $body-color;
    background-color: $surface;
    border-radius: 6px 6px 0 0;
}

/* ── Tree / sidebar ─────────────────────────────────────────────────────── */
QTreeWidget {
    background-color: $body-bg;
    border: none;
}


QTreeView::branch {
    background: transparent;
}

/* ── Table view ─────────────────────────────────────────────────────────── */
QTableView {
    background-color: $white;
    alternate-background-color: $body-bg;
    gridline-color: $border;
    border: 1px solid $border;
    border-radius: 6px;
}

QTableView::item {
    padding: 8px 12px;
    border: none;
    color: $body-color;
}

QTableView::item:hover {
    background-color: $surface;
    color: $body-color;
}

QTableView::item:selected {
    background-color: $surface-active;
    color: $body-color;
}

QTableView::item:selected:active {
    background-color: $surface-active;
    color: $body-color;
}

/* All widgets placed inside any table cell are transparent by default */
QTableView QWidget {
    background-color: transparent;
}

QHeaderView {
    background-color: $body-bg;
    border: none;
}

QHeaderView::section {
    background-color: $body-bg;
    color: $secondary;
    border: none;
    border-bottom: 2px solid $border;
    border-right: 1px solid $border;
    padding: 8px 12px;
    font-weight: 600;
    font-size: 12px;
}

QHeaderView::section:last {
    border-right: none;
}

QTableView QTableCornerButton::section {
    background-color: $body-bg;
    border: none;
    border-bottom: 2px solid $border;
    border-right: 1px solid $border;
}

/* ── Scrollbar ──────────────────────────────────────────────────────────── */
QScrollBar {
    background: transparent;
    margin: 0;
}

QScrollBar:vertical {
    width: 8px;
}

QScrollBar:horizontal {
    height: 8px;
}

QScrollBar::handle {
    background-color: $border-subtle;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    min-height: 32px;
    margin: 2px;
}

QScrollBar::handle:horizontal {
    min-width: 32px;
    margin: 2px;
}

QScrollBar::handle:hover {
    background-color: $muted;
}

QScrollBar::add-line,
QScrollBar::sub-line {
    width: 0;
    height: 0;
    background: transparent;
}

QScrollBar::add-page,
QScrollBar::sub-page {
    background: transparent;
}

/* ── Menu bar ───────────────────────────────────────────────────────────── */
QMenuBar {
    background-color: $white;
    color: $body-color;
    spacing: 2px;
}

QMenuBar::item {
    padding: 6px 12px;
    border-radius: 4px;
    background: transparent;
}

QMenuBar::item:selected {
    background-color: $surface;
    color: $body-color;
}

/* ── Dropdown menu ──────────────────────────────────────────────────────── */
QMenu {
    background-color: $white;
    border: 1px solid $border;
    border-radius: 8px;
    padding: 6px;
}

QMenu::item {
    border-radius: 4px;
    padding: 7px 24px;
    color: $body-color;
    background: transparent;
}

QMenu::item:selected {
    background-color: $surface;
    color: $body-color;
}

QMenu::separator {
    height: 1px;
    background: $border;
    margin: 6px 8px;
}

/* ── Status bar ─────────────────────────────────────────────────────────── */
QStatusBar {
    background-color: $body-bg;
    border-top: 1px solid $border;
    color: $secondary;
    font-size: 12px;
}

/* ── Tooltip ────────────────────────────────────────────────────────────── */
QToolTip {
    background-color: $body-color;
    color: $white;
    border: none;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 12px;
}

/* ── Top bar ────────────────────────────────────────────────────────────── */
#top_bar {
    background-color: $white;
    border-bottom: 1px solid $border;
}
#top_bar QPushButton {
    padding: 3px 10px;
}

/* ── Dialog boxes ───────────────────────────────────────────────────────── */
QDialog{
    background-color: $body-bg;
    color: $body-color;
}